{
  "$schema": "https://opencode.ai/config.json",
  "theme": "orng",
  "mcp": {
    "azureDevOps": {
      "type": "local",
      "command": ["npx", "-y", "@tiberriver256/mcp-server-azure-devops"],
      "environment": {
        "AZURE_DEVOPS_ORG_URL": "https://dev.azure.com/<ORGANIZATION>",
        "AZURE_DEVOPS_AUTH_METHOD": "pat",
        "AZURE_DEVOPS_PAT": "<TOKEN>",
        "AZURE_DEVOPS_DEFAULT_PROJECT": "<DEFAULT_PROJECT>"
      }
    }
  }
}
